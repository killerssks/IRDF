{
  "version": 2,
  "builds": [
    {
      "src": "main.py",
      "use": "@vercel/python"
    },
    {
      "src": "index.html",
      "use": "@vercel/static"
    },
    {
      "src": "styles.css",
      "use": "@vercel/static"
    },
    {
      "src": "app.js",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "main.py"
    },
    {
      "src": "/static/styles.css",
      "dest": "styles.css"
    },
    {
      "src": "/static/app.js",
      "dest": "app.js"
    },
    {
      "src": "/(.*)",
      "dest": "index.html"
    }
  ]
}
